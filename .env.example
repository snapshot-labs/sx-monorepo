# Permanent private voting - Docker stack configuration.
#
# Every value below has a working dev default baked into docker-compose.yml,
# so copying this file is optional for a local run. Override here for a real
# deployment. NEVER commit real keys.

# --- Keyper committee signing keys (dev defaults are deterministic) ---------
# These three keys define the committee. Their derived Ethereum addresses are
# written to each private proposal's te_keyper_addresses allow-list by the
# auto-dkg service, so the hub accepts the committee's DKG submissions.
# Production deployments MUST replace these with real, isolated keys held by
# three independent operators.
KEYPER_PRIVATE_KEY_1=0x4e057a764bb4fec72d8a09c7e04862cf293f87103459f216b41a885f36e27b6d
KEYPER_PRIVATE_KEY_2=0x99f276d9a8045c01649f153f69b1c446a24aee8fd546a147fe5e29cc061edc88
KEYPER_PRIVATE_KEY_3=0xfdf5c2f83276e56c374b54aaef3c0a3f989ad11d3f6a1faf29373e5e528ea94c

# --- Keyper DKG secret retention (shared by all keypers) --------------------
# Time in seconds to keep combined_share on disk after successful decrypt (0 = never prune).
# Default 172800 = 2 days.
# KEYPER_DKG_RETENTION_TIME=172800
# Background prune loop interval in seconds.
# KEYPER_DKG_PRUNE_INTERVAL_S=3600

# --- Hub / sequencer relayer keys (dummy dev values) ------------------------
HUB_RELAYER_PK=0x0123456789012345678901234567890123456789012345678901234567890123
SEQ_RELAYER_PK=0x4d39b13c6ed0c1a3d9e8e5f3b1c2a8e7f6d5c4b3a2918273645566f7e8d9c0b1

# --- Sequencer misc ----------------------------------------------------------
SEQ_AUTH_SECRET=1dfd84a695705665668c260222ded178d1f1d62d251d7bee8148428dac6d0487
WALLETCONNECT_PROJECT_ID=e6454bd61aba40b786e866a69bd4c5c6

# --- Host port mappings ------------------------------------------------------
# Only the host side is configurable; containers always talk to each other on
# the fixed internal ports. Override these if another process already holds a
# default port (e.g. something else on 3000). The UI expects the hub on 3000
# and sequencer on 3001 by default.
# HUB_PORT=3000
# SEQ_PORT=3001
# MYSQL_PORT=3306
# Note: keyper ports are not published to the host. Access via docker exec.
