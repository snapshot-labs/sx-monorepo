{
  "name": "agent",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "lint": "eslint . --ext .ts",
    "lint:fix": "yarn lint --fix",
    "build": "tsc",
    "migrate": "yarn knex migrate:latest",
    "predev": "yarn migrate",
    "dev": "nodemon src/index.ts",
    "prestart": "yarn migrate",
    "start": "node dist/src/index.js"
  },
  "eslintConfig": {
    "extends": "@snapshot-labs",
    "rules": {
      "no-console": "off"
    }
  },
  "prettier": "@snapshot-labs/prettier-config",
  "dependencies": {
    "@coinbase/cdp-sdk": "^1.44.1",
    "@snapshot-labs/sx": "^0.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.21.2",
    "knex": "^3.1.0",
    "pg": "^8.11.3",
    "viem": "^2.21.26"
  },
  "devDependencies": {
    "@snapshot-labs/eslint-config": "^0.1.0-beta.21",
    "@snapshot-labs/prettier-config": "^0.1.0-beta.19",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.5",
    "@types/node": "^18.14.4",
    "eslint": "^8.57.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.8.3"
  }
}
