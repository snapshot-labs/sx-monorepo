    "@types/cors": "^2.8.17",
    "async-mutex": "^0.4.0",
    "connection-string": "^4.4.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.21.2",
    "knex": "^3.1.0",
    "pino": "^9.8.0",
    "pino-pretty": "^13.1.1",
    "starknet": "7.6.4",
    "zod": "^3.22.4"
  },
