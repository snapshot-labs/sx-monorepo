{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "esnext",
    "module": "commonjs",
    "moduleResolution": "Node",
    "rootDir": "./",
    "outDir": "./build",
    "lib": ["esnext"],
    "esModuleInterop": true,
    "noImplicitAny": false,
    "noUncheckedIndexedAccess": false,
    "sourceMap": true,
    "inlineSources": true,
    "sourceRoot": "/"
  }
}
