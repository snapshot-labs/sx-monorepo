# Optional: Snapshot API key for higher rate limits
# https://docs.snapshot.box/tools/api/api-keys
SNAPSHOT_API_KEY=

# Optional: Override default hub API URL (offchain spaces)
SNAPSHOT_HUB_URL=https://hub.snapshot.org/graphql

# Optional: Override default Snapshot API URL (onchain Snapshot X and Governor spaces)
SNAPSHOT_API_URL=https://api.snapshot.box

# Base URL for OAuth metadata (required for hosted HTTP server)
BASE_URL=https://mcp.snapshot.box

# HTTP mode: secret used to sign JWT access tokens (HS256).
# Required, at least 32 characters. Generate with: openssl rand -hex 32
# Rotating this secret invalidates every issued token.
JWT_SECRET=

# HTTP mode: Coinbase CDP credentials (required).
# Each OAuth connect gets its own CDP-managed alias wallet for vote signing.
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=

# Stdio mode only: single local private key (ignored by HTTP server).
ALIAS_PRIVATE_KEY=
