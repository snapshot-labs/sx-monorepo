DATABASE_URL=postgres://postgres:password@localhost:5432/api
IS_INDEXER=true

# --- Inco confidential voting (Base Sepolia, chainId 84532) ---
# Restrict the indexer to Base Sepolia for fast iteration on the Inco demo.
# Comma-separated. Omit or unset to index every supported network.
ENABLED_NETWORKS=basesep
# Skip historical replay during tests by jumping to a recent head block.
# Get the current head with: cast block-number --rpc-url "$BASE_SEPOLIA_RPC_URL"
BASESEP_START_BLOCK=
