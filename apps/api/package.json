    "@as-integrations/express4": "^1.1.2",
    "@faker-js/faker": "^7.4.0",
    "@logtail/pino": "^0.5.5",
    "@snapshot-labs/checkpoint": "^0.1.0-beta.70",
    "@snapshot-labs/sx": "^0.1.0",
    "@types/node": "^22.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.1",
    "express": "^4.21.2",
    "graphql": "^16.11.0",
    "micro-starknet": "^0.2.3",
    "pino": "^9.9.0",
    "pino-pretty": "^13.1.1",
    "starknet": "7.6.4",
    "viem": "^2.38.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
