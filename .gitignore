# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
.pnp
.pnp.js
# this monorepo uses bun (bun.lock); keep stray npm lockfiles out
package-lock.json

# testing
coverage

# next.js
.next/
out/
build

# build
dist
dist.cjs

# misc
.DS_Store
*.pem
.idea

# debug
*.log*

# local env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# turbo
.turbo

# vercel
.vercel

# playwright related files
.browser

/legacy-docs

# Python bytecode (keyper service)
services/keypers/**/__pycache__/
services/keypers/**/*.pyc

# Keyper DKG state — encrypted secrets, must never be committed
keyper-state/

# MySQL data directory — bind-mounted from the container, must never be committed
mysql-data/
