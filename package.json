{
  "name": "sx-monorepo",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git@github.com:snapshot-labs/sx-monorepo.git"
  },
  "type": "module",
  "scripts": {
    "dev": "TURBO_TELEMETRY_DISABLED=1 turbo run dev --filter=!mana --filter=!api --filter=!highlight --filter=!auction",
    "dev:interactive": "node --experimental-strip-types --no-warnings=ExperimentalWarning ./scripts/dev-interactive.ts",
    "dev:electron": "TURBO_TELEMETRY_DISABLED=1 turbo run dev:electron",
    "build": "TURBO_TELEMETRY_DISABLED=1 turbo run build",
    "build:electron": "TURBO_TELEMETRY_DISABLED=1 ELECTRON=true turbo run build:electron",
    "test": "TURBO_TELEMETRY_DISABLED=1 turbo run test",
    "test:integration": "TURBO_TELEMETRY_DISABLED=1 turbo run test:integration",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "test:e2e:headed": "playwright test --config=playwright.config.ts --headed",
    "lint": "TURBO_TELEMETRY_DISABLED=1 turbo run lint lint:scripts",
    "lint:fix": "TURBO_TELEMETRY_DISABLED=1 turbo run lint:fix && bun run lint:scripts --fix",
    "lint:scripts": "eslint scripts/",
    "typecheck": "TURBO_TELEMETRY_DISABLED=1 turbo run typecheck",
    "release": "bun run build && changeset publish"
  },
  "prettier": "@snapshot-labs/prettier-config",
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@inquirer/prompts": "^7.10.1",
    "@playwright/test": "^1.56.1",
    "@snapshot-labs/eslint-config": "^0.1.0",
    "@snapshot-labs/prettier-config": "^0.1.0",
    "@types/decompress": "^4.2.7",
    "decompress": "^4.2.1",
    "eslint": "^9.0.0",
    "prettier": "^3.1.0",
    "turbo": "^2.8.0",
    "typescript": "^5.8.3"
  },
  "resolutions": {
    "error-ex": "1.3.2",
    "prettier": "3.2.5"
  },
  "engines": {
    "node": ">=22.6.0"
  },
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
