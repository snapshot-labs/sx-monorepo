{
  "name": "@snapshot-labs/lock",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/snapshot-labs/sx-monorepo.git",
    "directory": "packages/lock"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "type": "module",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./vue": {
      "import": "./dist/vue/index.js",
      "types": "./dist/vue/index.d.ts"
    }
  },
  "peerDependencies": {
    "vue": ">=3.5.0"
  },
  "scripts": {
    "dev": "tsc -w",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ./src",
    "lint:fix": "bun run lint --fix",
    "prepare": "bun run build",
    "prepublishOnly": "bun run lint"
  },
  "dependencies": {
    "0xsequence": "^2.2.10",
    "@coinbase/wallet-sdk": "^4.3.0",
    "@ethersproject/address": "^5.8.0",
    "@reown/appkit": "^1.8.8",
    "@safe-global/safe-apps-provider": "^0.18.6",
    "@safe-global/safe-apps-sdk": "^9.1.0",
    "events": "^3.3.0",
    "starknet": "7.6.4",
    "starknetkit": "^1.1.9",
    "thirdweb": "^5.88.6"
  },
  "devDependencies": {
    "@types/node": "^22.6.0",
    "typescript": "^5.8.3",
    "vue": "^3.5.30"
  },
  "files": [
    "dist/**/*",
    "src/**/*"
  ]
}
