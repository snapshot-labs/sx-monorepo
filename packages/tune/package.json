    "autoprefixer": "^10.4.16",
    "dayjs": "^1.11.10",
    "eslint-plugin-storybook": "^9.0.18",
    "postcss": "^8.4.30",
    "storybook": "^9.0.18",
    "tailwindcss": "^3.3.3",
    "typescript": "^5.8.3",
    "vite": "^8.0.0",
    "unplugin-auto-import": "^0.16.6",
    "unplugin-icons": "^0.17.0",
