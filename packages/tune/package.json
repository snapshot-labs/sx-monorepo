{
  "name": "@snapshot-labs/tune",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./theme": "./dist/theme.css",
    "./tailwind-preset": "./tailwind.config.ts",
    "./resolver": "./resolver.mjs"
  },
  "types": "./dist/index.d.ts",
  "prettier": "@snapshot-labs/prettier-config",
  "eslintConfig": {
    "extends": [
      "@snapshot-labs/vue",
      "plugin:storybook/recommended",
      "./.eslintrc-auto-import.json"
    ]
  },
  "scripts": {
    "build": "vite build && vue-tsc --project tsconfig.build.json",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint \"./src/**/*.{ts,vue}\"",
    "lint:fix": "yarn lint --fix",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "vue": ">=3.4.0"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.23",
    "@vueuse/core": "^10.4.1",
    "tippy.js": "^6.3.7",
    "vue-tippy": "^6.4.1"
  },
  "devDependencies": {
    "@iconify-json/heroicons-outline": "^1.1.7",
    "@iconify-json/heroicons-solid": "^1.1.8",
    "@snapshot-labs/eslint-config-vue": "^0.1.0",
    "@snapshot-labs/prettier-config": "^0.1.0",
    "@storybook/addon-a11y": "^9.0.18",
    "@storybook/addon-docs": "^9.0.18",
    "@storybook/addon-themes": "^9.0.18",
    "@storybook/vue3-vite": "^9.0.18",
    "@vitejs/plugin-vue": "^6.0.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.57.0",
    "eslint-plugin-storybook": "^9.0.18",
    "postcss": "^8.4.30",
    "storybook": "^9.0.18",
    "tailwindcss": "^3.3.3",
    "typescript": "^5.8.3",
    "vite": "npm:rolldown-vite@7.3.1",
    "unplugin-auto-import": "^0.16.6",
    "unplugin-icons": "^0.17.0",
    "unplugin-vue-components": "^0.25.2",
    "vue": "^3.4.15",
    "vue-router": "^4.2.5",
    "vue-tsc": "^3.0.3"
  }
